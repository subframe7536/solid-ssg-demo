{
  "name": "solid-ssg-demo",
  "version": "0.0.0",
  "private": true,
  "description": "",
  "license": "MIT",
  "type": "module",
  "scripts": {
    "start": "vite",
    "dev": "vite",
    "dev:page": "vite --base /solid-ssg-demo",
    "build": "bun run build:server && bun run build:client",
    "build:page": "bun run build:server --base /solid-ssg-demo && bun run build:client --base /solid-ssg-demo",
    "build:client": "vite build --outDir dist/client",
    "build:server": "vite build --ssr src/entry-server.tsx --outDir dist/server",
    "preview": "vite preview --outDir dist/client",
    "preview:page": "vite preview --outDir dist/client --base /solid-ssg-demo",
    "qa": "oxlint --fix && oxfmt && tsc --noEmit"
  },
  "dependencies": {
    "solid-js": "^1.9.5"
  },
  "devDependencies": {
    "@solidjs/router": "^0.16.1",
    "@subf/config": "^0.2.1",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "typescript": "^5.9.3",
    "vite": "^8",
    "vite-plugin-solid": "^2.11.6"
  }
}
